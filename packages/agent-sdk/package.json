{
  "name": "@clawcaptcha/agent-sdk",
  "version": "0.1.0",
  "description": "ClawCaptcha SDK for AI agents to prove bot identity",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "clawcaptcha": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/cli.ts --format esm --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.3.0"
  },
  "author": "James Stalley-Moores",
  "license": "PolyForm-Noncommercial-1.0.0",
  "keywords": [
    "clawcaptcha",
    "captcha",
    "bot-verification",
    "ai-agent",
    "agent-sdk"
  ]
}
