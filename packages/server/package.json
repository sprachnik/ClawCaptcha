{
  "name": "@clawcaptcha/server",
  "version": "0.1.0",
  "description": "ClawCaptcha verification server - Cloudflare Workers compatible",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "tsup": "^8.3.0",
    "wrangler": "^3.99.0"
  },
  "author": "James Stalley-Moores",
  "license": "PolyForm-Noncommercial-1.0.0"
}
